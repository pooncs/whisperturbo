{
  "mcpServers": {
    "task-manager": {
      "disabled": false,
      "timeout": 120,
      "type": "stdio",
      "command": "gorev-mcp",
      "args": [
        "serve",
        "mcp"
      ]
    },
    "context7": {
      "disabled": false,
      "timeout": 120,
      "type": "stdio",
      "command": "bunx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "DEFAULT_MINIMUM_TOKENS": ""
      }
    },
    "sequentialthinking": {
      "disabled": false,
      "timeout": 120,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  }
}